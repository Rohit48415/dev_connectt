<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Blog App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container" style="margin-top: 5rem;">
  <h2>Create Account</h2>
  <p style="text-align: center; color: #6b7280; margin-bottom: 2rem;">Join our blogging community</p>
  
  <form id="registerForm">
    <input type="text" id="name" placeholder="Full Name" required>
    <input type="email" id="email" placeholder="Email Address" required>
    <input type="password" id="password" placeholder="Password" required>
    <button type="submit">Create Account</button>
  </form>
  
  <p style="text-align: center; margin-top: 2rem; color: #6b7280;">
    Already have an account? <a href="/login" style="color: #6366f1; font-weight: 600; text-decoration: none;">Sign in</a>
  </p>
</div>

<script>
document.getElementById('registerForm').addEventListener('submit', async (e) => {
  e.preventDefault();

  const res = await fetch('/api/auth/register', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name: document.getElementById('name').value,
      email: document.getElementById('email').value,
      password: document.getElementById('password').value
    })
  });

  const data = await res.json();

  if (res.ok) {
    window.location.href = '/dashboard';
  } else {
    alert(data.message);
  }
});
</script>
</body>
</html>